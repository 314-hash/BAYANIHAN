# 🇵🇭 Bayanihan - Environment Variables Example
# Duplicate this file to '.env' and fill in your actual private keys and endpoints.
# DO NOT commit '.env' to public version control repositories!

# 🚀 Deployment Private Key (for Hardhat Deploy Scripts)
# Used to pay for gas fees when deploying contracts to BSC Testnet or Mainnet.
PRIVATE_KEY=""

# 🌐 RPC URLs (Defaults are provided if left empty, but custom ones can be specified here)
# BSC_TESTNET_RPC="https://data-seed-prebsc-1-s1.binance.org:8545/"
# BSC_MAINNET_RPC="https://bsc-dataseed.binance.org/"

# 🏢 Governance Security / Multi-Sig Setup
# If specified, the deployer script will transfer all core Admin and Governor permissions 
# to this address (e.g. Gnosis Safe) and revoke permissions from the deployer account.
MULTISIG_ADDRESS=""

# 🪪 Veramo KYC System Configuration
# Private key of the validator authorized to sign and verify DIDs and on-chain citizen updates.
VALIDATOR_PRIVATE_KEY="0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80"

# RPC URL for Veramo KYC service to connect to for bridging transactions
RPC_URL="http://127.0.0.1:8545"

# Deployed QuantumIdentity contract address (to bridge status on-chain)
QUANTUM_IDENTITY_ADDRESS="0x51a1ceb83b83f1985a81c295d1ff28afef186e02"

# 🔒 OpenBao Secrets Manager Configuration
# If configured, the KYC server fetches the validator private key from the OpenBao instance at runtime.
# OPENBAO_URL="http://127.0.0.1:8200"
# OPENBAO_TOKEN="your-bao-token-here"
# OPENBAO_SECRET_PATH="secret/data/bayanihan/kyc"
# OPENBAO_SECRET_KEY="validator_private_key"

# 🪙 Production Pre-Existing Tokens (Optional)
# If provided, the deployment script will hook these up instead of deploying fresh mock versions.
# BAYANI_TOKEN_ADDRESS=""
# BAYANI_NFT_ADDRESS=""

