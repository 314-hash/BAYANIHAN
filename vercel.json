{
  "version": 2,
  "name": "bayanihan-quantum-commerce-chain",
  "buildCommand": "",
  "outputDirectory": "frontend",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/app.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/v1/secret/data/bayanihan/kyc", "destination": "/api/v1/secret/data/bayanihan/kyc.js" },
    { "source": "/v1/ethereum/address", "destination": "/api/v1/ethereum/address.js" },
    { "source": "/v1/ethereum/sign-transaction", "destination": "/api/v1/ethereum/sign-transaction.js" },
    { "source": "/v1/ethereum/sign-message", "destination": "/api/v1/ethereum/sign-message.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
